# TAVL Lite 2.0 - Environment Configuration

# ===================================
# DATABASE CONFIGURATION (Primary - TAVL)
# ===================================
# TAVL Database Server (Primary for vehicle data - matches Python behavior)
DB_SERVER=192.168.20.253
DB_NAME=tavl2
DB_USER=developer
DB_PASSWORD=tavldev123
DB_DRIVER=ODBC Driver 17 for SQL Server

# ===================================
# CRM DATABASE (Secondary - for login/CRM details)
# ===================================
CRM_SERVER=192.168.21.33
CRM_NAME=ERP_Tracking
CRM_USER=sa
CRM_PASSWORD=iteck@1212

# ===================================
# COMMAND DATABASE (for SMS/GPRS commands - same server as CRM)
# ===================================
CMD_SERVER=192.168.21.33
CMD_NAME=tavl2
CMD_USER=sa
CMD_PASSWORD=iteck@1212

# ===================================
# TRACKING DATABASE (SQL Server - for historical tracking)
# ===================================
TRACKING_SERVER=192.168.20.1
TRACKING_NAME=Tracking
TRACKING_USER=sa
TRACKING_PASSWORD=iteck@12

# ===================================
# AUTOCALLS DATABASE (for robocall status)
# ===================================
AUTOCALLS_SERVER=192.168.20.1
AUTOCALLS_NAME=AutoCalls
AUTOCALLS_USER=sa
AUTOCALLS_PASSWORD=iteck@12

# ===================================
# POSTGRESQL DATABASE (for real-time GPS data)
# ===================================
PG_HOST=192.168.20.186
PG_PORT=5432
PG_DATABASE=Tracking
PG_USER=admin
PG_PASSWORD=admin123

# ===================================
# MDVR API CONFIGURATION
# ===================================
MDVR_BASE_URL=http://mdvr.itecknologi.com:8080
MDVR_ACCOUNT=dhl
MDVR_PASSWORD=dHl@mdvr

# ===================================
# GPS SERVER API CONFIGURATION
# ===================================
GPS_BASE_URL=http://webtrack.itecknologi.com/api
GPS_USERNAME=your_gps_username
GPS_PASSWORD=your_gps_password

# ===================================
# ASTERISK PBX CONFIGURATION (192.168.21.32)
# ===================================
ASTERISK_HOST=192.168.21.32
ASTERISK_SIP_PORT=5060
ASTERISK_SIP_TRANSPORT=udp
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=tavl
ASTERISK_AMI_PASSWORD=TavlAmi2024!
ASTERISK_CONTEXT=internal
ASTERISK_INBOUND_CONTEXT=from-trunk-uan

# Default SIP Extension (for Click-to-Call)
DEFAULT_SIP_EXTENSION=100
DEFAULT_SIP_PASSWORD=Agent100!

# SIP Extensions available: 100-109 (agents), 200 (supervisor)
# Passwords: Agent100! to Agent109!, Supervisor200!

# Asterisk SSH Access (for CDR recording playback)
ASTERISK_SSH_USER=iteckadmin
ASTERISK_SSH_PASSWORD=your_asterisk_ssh_password

# Auto-Call Configuration
ASTERISK_TRUNK=trunk-robocall
AUTOCALL_QUEUE=tavl-agents
AUTOCALL_CALLERID=02138658849

# UAN Configuration
UAN_TRUNK=trunk-uan
UAN_CID=02138658927

# ===================================
# FUSIONPBX + PBX_ADMIN POSTGRES (CDR / call history / extensions)
# Both databases live on the FreeSWITCH host's Postgres (FREESWITCH_HOST:5432).
# ===================================
FUSIONPBX_PG_DATABASE=fusionpbx
FUSIONPBX_PG_USER=fusionpbx
FUSIONPBX_PG_PASSWORD=your_fusionpbx_pg_password
PBX_ADMIN_PG_DATABASE=pbx_admin
PBX_ADMIN_PG_USER=pbx_admin
PBX_ADMIN_PG_PASSWORD=your_pbx_admin_pg_password
#
# PRODUCTION: leave the four *_PG_HOST / *_PG_PORT vars below UNSET.
# The code then falls back to FREESWITCH_HOST:5432 and connects directly.
#
# ⚠️ DEV ONLY — uncomment ONLY on a dev machine that cannot reach :5432 directly.
# These route Postgres through a local SSH tunnel. NEVER deploy them to production:
# they would point prod at a non-existent local tunnel, causing
# "FusionPBX database not available" / ECONNREFUSED 127.0.0.1:15432.
# Start the tunnel with:
#   sshpass -p "$FREESWITCH_SSH_PASSWORD" ssh -f -N -L 15432:127.0.0.1:5432 <ssh_user>@<freeswitch_host>
#FUSIONPBX_PG_HOST=127.0.0.1
#FUSIONPBX_PG_PORT=15432
#PBX_ADMIN_PG_HOST=127.0.0.1
#PBX_ADMIN_PG_PORT=15432

# ===================================
# ADMIN USER (full PBX config access)
# ===================================
ADMIN_USER=admin
ADMIN_PASSWORD=your_admin_password
ADMIN_JWT_SECRET=your_jwt_secret_key_min_32_chars

# ===================================
# APPLICATION CONFIGURATION
# ===================================
NODE_ENV=production
VITE_APP_NAME=iTecknologi Command Center
VITE_APP_VERSION=2.0.0

# ===================================
# INSTRUCTIONS
# ===================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Update the values above with your actual credentials
#
# 3. NEVER commit .env to git (it's in .gitignore)
#
# 4. Restart the app after changing values
