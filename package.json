{
  "name": "tavl-lite-v2",
  "version": "2.0.0",
  "description": "iTecknologi Command Center - Fleet Monitoring & Alert Management",
  "main": "dist-electron/main.js",
  "author": "iTeck Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run web:dev\"",
    "web:dev": "vite",
    "server:dev": "tsx watch server/index.ts",
    "start": "tsx server/index.ts",
    "start:prod": "npm run build && npm start",
    "build": "tsc && vite build",
    "build:dir": "tsc && vite build && electron-builder --dir",
    "preview": "vite preview",
    "electron:dev": "cross-env ELECTRON=true concurrently \"vite\" \"wait-on https://localhost:5173 && electron .\"",
    "electron:build": "cross-env ELECTRON=true vite build && electron-builder",
    "electron:build:dir": "cross-env ELECTRON=true vite build && electron-builder --dir",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.17.19",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.18",
    "@types/maplibre-gl": "^1.13.2",
    "axios": "^1.6.5",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "date-fns": "^3.0.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "framer-motion": "^11.0.3",
    "immer": "^10.0.3",
    "leaflet": "^1.9.4",
    "leaflet-rotatedmarker": "^0.2.0",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.309.0",
    "maplibre-gl": "^5.17.0",
    "modesl": "^1.2.1",
    "mssql": "^10.0.2",
    "multer": "^2.1.1",
    "pg": "^8.17.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.21.1",
    "sip.js": "^0.21.2",
    "tailwind-merge": "^2.2.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.8",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/mssql": "^9.1.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "postcss": "^8.4.33",
    "prettier": "^3.2.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-electron": "^0.28.2",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.iteck.tavl-lite-v2",
    "productName": "iTecknologi Command Center",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
